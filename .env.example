# Auth (required in production, ≥32 chars)
AUTH_SECRET="your-32-character-secret-here"

# Site URL (must match your Vercel domain or localhost)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database (PostgreSQL/Neon) — use the pooled (`-pooler`) host at runtime.
# Start with one connection per serverless instance to avoid exhausting the
# database when the platform scales out. Increase only after monitoring usage.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require&connection_limit=1&pool_timeout=15&connect_timeout=15"

# Database — use the non-pooled host for Prisma migrations.
# Required for `pnpm db:migrate` and `pnpm db:migrate:deploy`.
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Vercel Blob (uploads, resumes)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Resend (Email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="TechBox <onboarding@resend.dev>"
CONTACT_EMAIL="hello@example.com"

# Upstash Redis (Rate Limiting) — optional, in-memory fallback if missing
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# AI Chat (public chatbot — server model only)
CHAT_API_KEY="sk-..."
CHAT_BASE_URL="https://api.openai.com/v1"
CHAT_MODEL="gpt-4o-mini"

# Sentry (Monitoring)
NEXT_PUBLIC_SENTRY_DSN="https://..."
SENTRY_DSN="https://..."  # Server-side (can be same as NEXT_PUBLIC_)

# Seed (local development only)
# SEED_DEFAULT_PASSWORD="set-a-secure-password"

# Payments — disabled by default. Shop is catalog-only.
# PAYMENTS_ENABLED="true"
# ZARIN_MERCHANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
