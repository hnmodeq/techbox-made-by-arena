# Neon Serverless PostgreSQL Pooler
# Get this from your Neon project dashboard -> Connection Details -> Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct URL for Prisma Migrate / db push when using Neon PostgreSQL
# Get this from your Neon project dashboard -> Connection Details -> Direct connection
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST.aws.neon.tech/neondb?sslmode=require"

AUTH_SECRET="techbox-dev-secret-change-me-32chars-min"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional integrations
# CHAT_API_KEY=""
# CHAT_BASE_URL="https://api.openai.com/v1"
# CHAT_MODEL="gpt-4o-mini"
# ZARIN_MERCHANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
