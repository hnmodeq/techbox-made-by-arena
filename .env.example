# ---- Database (Neon PostgreSQL) ----
# BOTH variables are REQUIRED on Vercel (Project Settings -> Environment Variables)
# and in any CI that runs `prisma db push`. Without DIRECT_URL the Prisma
# schema validation fails ("Environment variable not found: DIRECT_URL") and the
# build cannot create the tables, which makes every stats/like/view/comment
# request fall back to hardcoded numbers.
#
# The pooled URL (DATABASE_URL) is used by the app at runtime.
# The direct (non-pooled) URL (DIRECT_URL) is used by Prisma migrations / db push.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST-direct/neondb?sslmode=require"

# ---- AI helper ----
GAPGPT_API_KEY=your-gapgpt-key
GAPGPT_BASE_URL=https://api.gapgpt.app/v1

# ---- Auth ----
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Public base URL (used for absolute links / OG tags)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
