# ---- Database (Neon PostgreSQL) ----
# DATABASE_URL is required in Vercel (Project Settings -> Environment Variables)
# and anywhere the app runs. Use the Neon pooled URL for normal runtime traffic.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# Optional: keep a direct (non-pooled) Neon URL available for manual migration
# commands if you need it, but prisma/schema.prisma intentionally does not
# require DIRECT_URL so builds and deployment checks do not fail when only
# DATABASE_URL is configured.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ---- AI helper ----
GAPGPT_API_KEY=your-gapgpt-key
GAPGPT_BASE_URL=https://api.gapgpt.app/v1

# ---- Auth ----
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Public base URL (used for absolute links / OG tags)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
