generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String  @id @default(cuid())
  name     String
  username String  @unique
  email    String
  role     String
  modules  String  @default("[]")
  avatar   String?
  password String

  posts    Post[]
  comments Comment[]
}

model Post {
  id         String   @id @default(cuid())
  slug       String
  module     String
  title      String
  excerpt    String   @default("")
  content    String   @default("")
  image      String?
  tags       String   @default("[]")
  category   String?
  authorId   String?
  authorName String   @default("تحریریه")
  date       DateTime @default(now())
  dateFa     String   @default("")
  likes      Int      @default(0)
  views      Int      @default(0)
  published  Boolean  @default(true)

  author   User?     @relation(fields: [authorId], references: [id])
  comments Comment[]

  @@unique([module, slug], name: "module_slug")
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  parentId   String?
  authorId   String?
  authorName String   @default("مهمان")
  text       String
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  createdAt  DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User?     @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  votes   CommentVote[]
}

model CommentVote {
  id          String  @id @default(cuid())
  fingerprint String
  commentId   String
  vote        Int

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, commentId], name: "fingerprint_commentId")
}

model Like {
  id          String @id @default(cuid())
  fingerprint String
  module      String
  slug        String

  @@unique([fingerprint, module, slug], name: "fingerprint_module_slug")
}
