generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String
  username String  @unique
  email    String  @unique
  role     String
  roleFa   String?
  status   String  @default("active")
  job      String?
  bio      String?
  birthday String?
  modules  Json?
  avatar   String?
  password String
  emailVerified         DateTime?
  sessionsInvalidatedAt DateTime?

  /// Verification badge type: "content" | "org" | "user" | null (none)
  verifiedType  String?
  /// For org users: admin-written label shown in tooltip, e.g. "کارشناس فناوری - بانک ملت"
  verifiedLabel String?

  posts    Post[]
  comments Comment[]
  ratings  Rating[]
  notificationState UserNotificationState?
  newsReads UserNewsRead[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  verificationRequests VerificationRequest[]

  // Follow system
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")

  @@index([role, status], name: "user_role_status_idx")
  @@index([status], name: "user_status_idx")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId])
}

model Post {
  id         String   @id @default(cuid())
  slug       String
  module     String
  title      String
  excerpt    String   @default("")
  content    String   @default("")
  image      String?
  videoUrl   String?
  videoDuration String?
  videoMimeType String?
  videoFileSize String?
  gallery    Json?
  tags       Json?
  category   String?
  seoTitle   String?
  seoDescription String?
  brand      String?
  model      String?
  sku        String?
  priceLabel String?
  priceAmount   Float?
  sourcePriceAmount Float?   // Source price (e.g. 1000 USD) – hidden, admin only
  sourceCurrency String? @default("USD") // USD, EUR, AED
  priceAdjustmentPercent Float? @default(0) // Per-product adjustment % (-100..+100)
  sellerBenefitPercent Float? @default(35) // Company benefit % (e.g. 35)
  discountPercent Int?
  discountEndsAt DateTime?
  availability String?
  warranty   String?
  specs      Json?
  authorId   String?
  authorName String   @default("تحریریه")
  date       DateTime @default(now())
  dateFa     String   @default("")
  likes         Int      @default(0)
  views         Int      @default(0)
  rating        Float?
  ratingCount   Int      @default(0)
  solved        Boolean? @default(false)
  acceptedCommentId String? @unique
  fileName      String?
  fileUrl       String?
  fileSize      String?
  downloadCount Int      @default(0)
  published     Boolean  @default(true)
  status        String   @default("published")
  deletedAt     DateTime?
  deletedBy     String?

  author   User?     @relation(fields: [authorId], references: [id])
  comments Comment[]
  ratings  Rating[]
  revisions PostRevision[]
  likeRows Like[]   @relation("PostLikes")
  acceptedComment Comment? @relation("AcceptedAnswer", fields: [acceptedCommentId], references: [id], onDelete: SetNull)

  @@unique([module, slug], name: "module_slug")
  @@index([module, published, date], name: "post_module_published_date_idx")
  @@index([published, date], name: "post_published_date_idx")
  @@index([authorId], name: "post_author_idx")
  @@index([module, category], name: "post_module_category_idx")
  @@index([module, published, views], name: "post_module_published_views_idx")
  @@index([module, published, likes], name: "post_module_published_likes_idx")
  @@index([module, published, rating], name: "post_module_published_rating_idx")
  @@index([date], name: "post_date_idx")
}


model UserNotificationState {
  id         String   @id @default(cuid())
  userId     String   @unique
  lastReadAt DateTime @default(dbgenerated("'1970-01-01 00:00:00'::timestamp"))
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastReadAt], name: "user_notification_last_read_idx")
}

model UserNewsRead {
  id     String   @id @default(cuid())
  userId String
  slug   String
  readAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug], name: "userId_slug")
  @@index([userId, readAt], name: "user_news_read_user_read_idx")
  @@index([slug], name: "user_news_read_slug_idx")
}

model Rating {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  value       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], name: "postId_userId")
  @@index([postId], name: "rating_post_idx")
  @@index([userId], name: "rating_user_idx")
  @@index([createdAt], name: "rating_created_idx")
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  parentId   String?
  authorId   String?
  authorName String   @default("مهمان")
  text       String
  status     String   @default("approved")
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  createdAt  DateTime @default(now())
  editedAt   DateTime?
  deletedAt  DateTime?
  deletedBy  String?

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User?     @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  votes   CommentVote[]
  acceptedByPost Post? @relation("AcceptedAnswer")

  @@index([postId, status, createdAt], name: "comment_post_status_created_idx")
  @@index([authorId, createdAt], name: "comment_author_created_idx")
  @@index([parentId], name: "comment_parent_idx")
  @@index([status, createdAt], name: "comment_status_created_idx")
}

model CommentVote {
  id          String  @id @default(cuid())
  fingerprint String
  commentId   String
  vote        Int

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, commentId], name: "fingerprint_commentId")
  @@index([commentId], name: "comment_vote_comment_idx")
}

model Like {
  id          String   @id @default(cuid())
  fingerprint String
  userId      String?
  module      String
  slug        String
  postId      String?
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
  deletedBy   String?

  post Post? @relation("PostLikes", fields: [postId], references: [id], onDelete: SetNull)

  @@unique([fingerprint, module, slug], name: "fingerprint_module_slug")
  @@index([module, slug, createdAt], name: "like_module_slug_created_idx")
  @@index([userId, createdAt], name: "like_user_created_idx")
  @@index([postId], name: "like_post_idx")
  @@index([createdAt], name: "like_created_idx")
}


model SlugRedirect {
  id           String   @id @default(cuid())
  sourceModule String
  sourceSlug   String
  targetModule String
  targetSlug   String
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([sourceModule, sourceSlug], name: "source_module_slug")
  @@index([targetModule, targetSlug], name: "redirect_target_idx")
  @@index([createdAt], name: "redirect_created_idx")
}

model PostRevision {
  id        String   @id @default(cuid())
  postId    String
  oldTitle  String?
  oldContent String?
  oldImage  String?
  editedBy  String?
  editedAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, editedAt], name: "post_revision_post_edited_idx")
}

model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  dateGr      DateTime @unique
  dateFa      String   @unique
  year        Int
  yearFa      Int
  importance  Int      @default(5)
  tags        Json?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments TimelineComment[]
  likes    TimelineLike[]

  @@index([published, dateGr], name: "timeline_event_published_date_idx")
  @@index([year], name: "timeline_event_year_idx")
  @@index([importance], name: "timeline_event_importance_idx")
}

model TimelineComment {
  id         String   @id @default(cuid())
  eventId    String
  parentId   String?
  authorName String   @default("مهمان")
  text       String
  status     String   @default("approved")
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  createdAt  DateTime @default(now())

  event   TimelineEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent  TimelineComment?    @relation("TimelineCommentReplies", fields: [parentId], references: [id])
  replies TimelineComment[]   @relation("TimelineCommentReplies")
  votes   TimelineCommentVote[]

  @@index([eventId, status, createdAt], name: "timeline_comment_event_status_created_idx")
  @@index([parentId], name: "timeline_comment_parent_idx")
  @@index([status, createdAt], name: "timeline_comment_status_created_idx")
}

model TimelineCommentVote {
  id          String  @id @default(cuid())
  fingerprint String
  commentId   String
  vote        Int

  comment TimelineComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, commentId], name: "timeline_fingerprint_commentId")
  @@index([commentId], name: "timeline_comment_vote_comment_idx")
}

model TimelineLike {
  id          String   @id @default(cuid())
  fingerprint String
  userId      String?
  eventId     String
  createdAt   DateTime @default(now())

  event TimelineEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, eventId], name: "timeline_fingerprint_eventId")
  @@index([eventId, createdAt], name: "timeline_like_event_created_idx")
  @@index([userId, createdAt], name: "timeline_like_user_created_idx")
  @@index([createdAt], name: "timeline_like_created_idx")
}

model NewsletterSubscriber {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  active           Boolean   @default(true)
  unsubscribeToken String    @unique @default(cuid())
  unsubscribedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([active, createdAt])
}

/// A sent newsletter blast. Stores what was sent (subject, header/footer used,
/// selected items) and basic delivery stats, so the admin has a history.
model NewsletterCampaign {
  id             String    @id @default(cuid())
  subject        String
  headerHtml     String?
  footerHtml     String?
  items          Json      // Array of { module, slug, title, excerpt, image, url, dateFa }
  recipientCount Int       @default(0)
  status         String    @default("sent") // sent | failed
  sentBy         String?
  sentAt         DateTime  @default(now())
  createdAt      DateTime  @default(now())

  @@index([sentAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Job {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  type        String
  remote      Boolean  @default(false)
  team        String
  excerpt     String
  description String   @db.Text
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications JobApplication[]

  @@index([active, order])
}

model JobApplication {
  id         String   @id @default(cuid())
  jobId      String
  name       String
  email      String
  phone      String
  resumeUrl  String
  resumeName String
  message    String?  @db.Text
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  type      String   @default("contact") // contact | feedback | support
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  status    String   @default("new") // new | read | resolved
  createdAt DateTime @default(now())

  replies   TicketReply[]

  @@index([createdAt])
  @@index([type, status, createdAt])
  @@index([email, type, createdAt])
}

/// Replies in a support ticket conversation (both user and admin messages).
model TicketReply {
  id          String   @id @default(cuid())
  ticketId    String
  authorName  String
  authorEmail String?
  authorRole  String   @default("user") // user | admin
  message     String   @db.Text
  createdAt   DateTime @default(now())

  ticket ContactSubmission @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string or plain value
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
  @@index([order])
}

model SavedContent {
  id        String   @id @default(cuid())
  userId    String
  module    String
  slug      String
  createdAt DateTime @default(now())

  @@unique([userId, module, slug], name: "SavedContent_user_module_slug_key")
  @@index([userId, createdAt], name: "SavedContent_user_created_idx")
}

/// Badge verification request submitted by a user.
/// type: "content" = blue tick, "org" = purple tick, "user" = yellow tick
model VerificationRequest {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "content" | "org" | "user"
  status    String   @default("pending") // "pending" | "approved" | "denied"

  // Common fields
  message   String   @db.Text
  phone     String?
  nationalId String?

  // Blue-tick (content creator) extras
  modules   String[] // selected content modules

  // Purple-tick (org) extras
  orgName          String?
  orgNationalId    String?
  orgPosition      String?   // applicant's position in org
  orgApplicantName String?   // full legal name

  // Admin response
  adminNote    String?  @db.Text
  reviewedBy   String?  // admin userId
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model ConsultationRequest {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  userEmail String?
  items     Json     // Array of { slug, title }
  notes     String?
  status    String   @default("pending") // pending | contacted | quoted | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt], name: "consultation_status_created_idx")
  @@index([createdAt], name: "consultation_created_idx")
}

/// Audit log for tracking admin actions across the platform.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?             // who performed the action
  userName  String   @default("") // denormalized for display
  action    String              // e.g. "post.publish", "user.ban", "settings.update"
  target    String?             // e.g. "post:blog/my-slug", "user:abc123"
  details   String?  @db.Text   // JSON string with additional context
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
}

/// Search query analytics — tracks what users search for on the public site.
model SearchLog {
  id        String   @id @default(cuid())
  query     String              // the search term
  results   Int      @default(0) // number of results returned
  userId    String?             // null for anonymous
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([query, createdAt])
}

/// Orders for the shop.
model Order {
  id            String   @id @default(cuid())
  orderNumber   String   @unique   // e.g. "ORD-1720000000-abc123"
  userId        String?             // null for guest checkout
  status        String   @default("pending") // pending | paid | processing | shipped | delivered | cancelled | refunded

  // Customer info
  customerName  String
  customerEmail String?
  customerPhone String
  customerAddress String @db.Text
  customerPostalCode String
  customerCity  String?

  // Pricing
  subtotal      Float
  shippingCost  Float    @default(0)
  tax           Float    @default(0)
  total         Float
  currency      String   @default("IRR")

  // Payment
  paymentMethod String?  // zarinpal | manual
  paymentId     String?  // Zarinpal authority/ref_id
  paidAt        DateTime?

  // Notes
  adminNote     String?  @db.Text
  customerNote  String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         OrderItem[]

  @@index([userId])
  @@index([status, createdAt])
  @@index([orderNumber])
}

/// Individual items within an order.
model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  postId    String?            // link to Post if exists
  slug      String
  module    String
  title     String
  image     String?
  price     Float              // price at time of order
  quantity  Int    @default(1)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
