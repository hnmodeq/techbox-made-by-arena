generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String
  username String  @unique
  email    String
  role     String
  roleFa   String?
  status   String  @default("active")
  job      String?
  birthday String?
  modules  String  @default("[]")
  avatar   String?
  password String

  posts    Post[]
  comments Comment[]
  ratings  Rating[]
  notificationState UserNotificationState?
}

model Post {
  id         String   @id @default(cuid())
  slug       String
  module     String
  title      String
  excerpt    String   @default("")
  content    String   @default("")
  image      String?
  videoUrl   String?
  videoDuration String?
  videoMimeType String?
  videoFileSize String?
  gallery    String   @default("[]")
  tags       String   @default("[]")
  category   String?
  seoTitle   String?
  seoDescription String?
  brand      String?
  model      String?
  sku        String?
  priceLabel String?
  availability String?
  warranty   String?
  specs      String   @default("{}")
  authorId   String?
  authorName String   @default("تحریریه")
  date       DateTime @default(now())
  dateFa     String   @default("")
  likes         Int      @default(0)
  views         Int      @default(0)
  rating        Float?
  ratingCount   Int      @default(0)
  solved        Boolean? @default(false)
  fileName      String?
  fileUrl       String?
  fileSize      String?
  downloadCount Int      @default(0)
  published     Boolean  @default(true)

  author   User?     @relation(fields: [authorId], references: [id])
  comments Comment[]
  ratings  Rating[]

  @@unique([module, slug], name: "module_slug")
}


model UserNotificationState {
  id         String   @id @default(cuid())
  userId     String   @unique
  lastReadAt DateTime @default(dbgenerated("'1970-01-01 00:00:00'::timestamp"))
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rating {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  value       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], name: "postId_userId")
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  parentId   String?
  authorId   String?
  authorName String   @default("مهمان")
  text       String
  status     String   @default("approved")
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  createdAt  DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User?     @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  votes   CommentVote[]
}

model CommentVote {
  id          String  @id @default(cuid())
  fingerprint String
  commentId   String
  vote        Int

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, commentId], name: "fingerprint_commentId")
}

model Like {
  id          String   @id @default(cuid())
  fingerprint String
  userId      String?
  module      String
  slug        String
  createdAt   DateTime @default(now())

  @@unique([fingerprint, module, slug], name: "fingerprint_module_slug")
}


model SlugRedirect {
  id           String   @id @default(cuid())
  sourceModule String
  sourceSlug   String
  targetModule String
  targetSlug   String
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([sourceModule, sourceSlug], name: "source_module_slug")
}

model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  dateGr      DateTime @unique
  dateFa      String   @unique
  year        Int
  yearFa      Int
  importance  Int      @default(5)
  tags        String   @default("[]")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments TimelineComment[]
  likes    TimelineLike[]
}

model TimelineComment {
  id         String   @id @default(cuid())
  eventId    String
  parentId   String?
  authorName String   @default("مهمان")
  text       String
  status     String   @default("approved")
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  createdAt  DateTime @default(now())

  event   TimelineEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent  TimelineComment?    @relation("TimelineCommentReplies", fields: [parentId], references: [id])
  replies TimelineComment[]   @relation("TimelineCommentReplies")
  votes   TimelineCommentVote[]
}

model TimelineCommentVote {
  id          String  @id @default(cuid())
  fingerprint String
  commentId   String
  vote        Int

  comment TimelineComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, commentId], name: "timeline_fingerprint_commentId")
}

model TimelineLike {
  id          String   @id @default(cuid())
  fingerprint String
  userId      String?
  eventId     String
  createdAt   DateTime @default(now())

  event TimelineEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, eventId], name: "timeline_fingerprint_eventId")
}
