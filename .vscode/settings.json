{
  "prisma.pinToPrisma6": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.wordWrap": "on",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,

  "files.exclude": {
    "**/.git": true,
    "**/.env*": true,
    "**/.gitattributes": true,
    "**/.gitignore": true,
    "**/.github": true,
    "**/docker-compose.yml": true,
    "**/next-env.d.ts": true,
    "**/tailwind.config.ts": true,
    "**/tsconfig.json": true,
    "**/components.json": true,
    "**/next.config.ts": true,
    "**/eslint.config.mjs": true,
    "**/package.json": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/pnpm-workspace.yaml": true,
    "**/postcss.config.mjs": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/.tsbuildinfo": true,
    "**/.coverage": true,
    "**/pnpm-debug.log": true,
    "**/tsconfig.tsbuildinfo": true,
    "**/next.config.mjs": true,
    "**/.config" : true,
    "**/.continue" : true,
    "**/.vercel" : true,
    "**/TIMELINE_ARCHITECTURE.md": true,
    "**/docker-compose.yml.bak": true,
    "**/.npmrc": true,
    "**/instrumentation.ts": true,
    "**/playwright.config.ts": true,
    "**/sentry.client.config.ts": true,
    "**/sentry.edge.config.ts": true,
    "**/sentry.server.config.ts": true,
    "**/vercel.json": true,
    "**/PROJECT_UNDERSTANDING.md": true,
    "**/README.md": true,
    "**/TODO.md": true,
    "**/proxy.ts":true,
    "**/vitest.config.ts":true,
  },
  "js/ts.tsdk.path": "node_modules\\typescript\\lib"
}
