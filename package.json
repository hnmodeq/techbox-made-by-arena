{
  "name": "techbox",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit --pretty false",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:baseline": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql && prisma migrate resolve --applied 0_init",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "data": "node scripts/data.cjs",
    "tree": "node scripts/tree.cjs",
    "prisma:generate": "prisma generate",
    "db:backfill-metadata": "tsx prisma/backfill-metadata.ts",
    "db:seed-blob-content": "tsx prisma/seed-blob-content.ts",
    "check:content": "tsx scripts/checks/content.ts",
    "check:blob": "tsx scripts/checks/blob.ts",
    "check:db": "tsx scripts/checks/db.ts",
    "check:all": "tsx scripts/checks/all.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "playwright:install": "playwright install chromium",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/vazirmatn": "^5.2.8",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.10",
    "@sentry/nextjs": "^10.64.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "hls.js": "^1.6.16",
    "jose": "^5.10.0",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "openai": "^6.45.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.76",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "rehype-sanitize": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.16",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.12.1"
}
