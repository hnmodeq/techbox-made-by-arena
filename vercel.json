{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": false
  },
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  }
}